# Python
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
.env

# Large model weights are NOT committed (exceed the submission size limit).
# The ~1.1 GB XLM-RoBERTa transformer is hosted on HuggingFace instead:
#   https://huggingface.co/FarisTheCoder/xlmr-telco-sentiment
models/xlmr_final/
*.safetensors
*.bin

# The tiny TF-IDF baseline models and result files ARE committed so the CPU
# pipeline (baseline + evaluation) runs turnkey without retraining.
*.pkl
!models/baseline_lr.pkl
!models/baseline_svm.pkl

# Editor / OS
.idea/
.vscode/
.DS_Store
.ipynb_checkpoints/
~$*
*.log
